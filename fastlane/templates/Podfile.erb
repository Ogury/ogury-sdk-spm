source "https://github.com/Ogury/ogury-cocoapods-repository.git"
source 'https://cdn.cocoapods.org/'

<% if artifactory_repository_name != nil %>
plugin 'cocoapods-art', :sources => [
  '<%= artifactory_repository_name %>',
]
<% end %>

platform :ios, "12.0"
use_frameworks!
workspace "OgurySdks.xcworkspace"

install! 'cocoapods',:warn_for_multiple_pod_sources => false, :warn_for_unused_master_specs_repo => false

target 'LegacyTestApp' do
  project 'sdk-ads-ios/LegacyTestApp/LegacyTestApp'
  pod 'RxSwift', "6.2.0" # 6.5+ introduced concurrency supports which breaks with iOS under 13
  pod 'RxCocoa', "6.2.0" # 6.5+ introduced concurrency supports which breaks with iOS under 13
  pod 'Yaml'
  pod 'DDPopoverBackgroundView'
  pod "SnapKit"
end

target "OguryCoreTests" do
  project "sdk-core-ios/OguryCore"
  pod "OCMock", :git=> 'https://github.com/SDKOguryDev/ocmock', :branch => 'master'
end

target "OguryAdsTests" do
  project "sdk-ads-ios/OguryAdsSDK"
  pod "OCMock", :git=> 'https://github.com/SDKOguryDev/ocmock', :branch => 'master'
end

target "AdsCardLibrary-art" do
  project "sdk-ads-ios/AdsCardLibrary/AdsCardLibrary"
  pod "OguryCore<%= framework_suffix %>", "<%= ogury_core_version %>"
end

#OguryCardAdapter
target "OguryCardAdapter-art" do
  project "AdsCardAdapter/OguryCardAdapter/OguryCardAdapter"
  pod "OgurySdk<%= framework_suffix %>", "<%= ogury_sdk_version %>"
end
#MaxCardAdapter
target "MaxCardAdapter" do
  project "AdsCardAdapter/MaxCardAdapter/MaxCardAdapter"
  pod 'AppLovinSDK'
  pod 'AppLovinMediationOguryPresageAdapter'
end
#AdMobCardAdapter
target "AdMobCardAdapter" do
  project "AdsCardAdapter/AdMobCardAdapter/AdMobCardAdapter"
  pod 'Google-Mobile-Ads-SDK'
  pod 'OguryMediationGoogleMobileAds'
end
#UnityLevelPlayCardAdapter
target "UnityLevelPlayCardAdapter" do
  project "AdsCardAdapter/UnityLevelPlayCardAdapter/UnityLevelPlayCardAdapter"
  pod 'IronSourceSDK'
  pod 'IronSourceOguryAdapter'
end
#Prebid
target "PrebidCardAdapter" do
  project "AdsCardAdapter/PrebidCardAdapter/PrebidCardAdapter"
  pod 'PrebidMobile'
end

#Ads Test Apps
def testAppBasePods
  pod 'InMobiCMP', '2.0.1'
  pod 'Google-Mobile-Ads-SDK'
end

target "AdsTestApp-Devc" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end
target "AdsTestApp-Staging" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end
target "AdsTestApp-Prod" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end
target "MaxTestApp" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
  pod 'AppLovinSDK'
  pod 'AppLovinMediationOguryPresageAdapter'
end
target "AdMobTestApp" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
  pod 'OguryMediationGoogleMobileAds'
end
target "UnityLevelPlayTestApp" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end
target "PrebidTestApp-devc" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
  pod 'PrebidMobile'
end
target "PrebidTestApp-staging" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
  pod 'PrebidMobile'
end
target "PrebidTestApp" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
  pod 'PrebidMobile'
end

target "AdsTestApp-Devc-art" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end
target "AdsTestApp-Staging-art" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end
target "AdsTestApp-Prod-art" do
  project "sdk-ads-ios/AdsTestApp/AdsTestApp"
  testAppBasePods
end

#Wrapper
target 'OguryWrapperTests' do
  project "sdk-wrapper-ios/OguryWrapper/OguryWrapper.xcodeproj/"
    inherit! :complete
    pod 'OCMock', :git=> 'https://github.com/SDKOguryDev/ocmock', :branch => 'master'
end

target 'OguryWrapperTestApp' do
  project "sdk-wrapper-ios/OguryWrapperTestApp/OguryWrapperTestApp.xcodeproj"
  pod 'InMobiCMP', '2.0.1'
end


post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = "10.0"
    end
  end
end
