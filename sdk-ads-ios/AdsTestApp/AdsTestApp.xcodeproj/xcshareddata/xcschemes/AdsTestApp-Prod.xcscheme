      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Run Script"
               scriptText = "echo &quot;&#x1f50d; Locating the correct Info.plist...&quot;&#10;# Retrieve the correct Info.plist file path using Xcode&apos;s INFOPLIST_FILE&#10;APP_PLIST=&quot;${INFOPLIST_FILE}&quot;&#10;# Check if INFOPLIST_FILE is set&#10;if [ -z &quot;$APP_PLIST&quot; ]; then&#10;    echo &quot;&#x274c; ERROR: INFOPLIST_FILE is not set.&quot;&#10;    exit 1&#10;fi&#10;echo &quot;&#x1f4c2; INFOPLIST_FILE: $APP_PLIST&quot;&#10;# Check if the Info.plist exists&#10;if [ ! -f &quot;$APP_PLIST&quot; ]; then&#10;    echo &quot;&#x274c; ERROR: Info.plist not found at $APP_PLIST&quot;&#10;    exit 1&#10;fi&#10;echo &quot;&#x1f4cc; Using Info.plist from: $APP_PLIST&quot;&#10;&#10;APP_VERSION=&quot;${APP_VERSION}&quot;&#10;CONFIG_FILE=&quot;$(cd &quot;$PROJECT_DIR/../..&quot; &amp;&amp; pwd)/sdk-wrapper-ios/OguryWrapper/Configurations/Configuration.xcconfig&quot;&#10;&#10;echo &quot;&#x2764;&#xfe0f; Looking for xcconfig file at: $CONFIG_FILE&quot;&#10;&#10;# Extract the framework version from the xcconfig file&#10;if [ -f &quot;$CONFIG_FILE&quot; ]; then&#10;    FRAMEWORK_VERSION=$(grep -E &quot;^MARKETING_VERSION&quot; &quot;$CONFIG_FILE&quot; | cut -d &apos;=&apos; -f2 | tr -d &apos; &apos;)&#10;else&#10;    echo &quot;&#x274c; .xcconfig file not found! ${CONFIG_FILE}&quot;&#10;    FRAMEWORK_VERSION=&quot;Unknown&quot;&#10;fi&#10;&#10;CONFIG_FILE_DEBUG=&quot;${SRCROOT}/AdsTestApp/Config/Ogury/Prod/config.debug.xcconfig&quot;&#10;CONFIG_FILE_RELEASE=&quot;${SRCROOT}/AdsTestApp/Config/Ogury/Prod/config.release.xcconfig&quot;&#10;KEY_TO_UPDATE=&quot;VERSION&quot;&#10;NEW_VALUE=&quot;${APP_VERSION}+ogury-dev.${FRAMEWORK_VERSION}&quot;&#10;&#10;# Check if the config file exists&#10;if [ -f &quot;$CONFIG_FILE_DEBUG&quot; ]; then&#10;    # Use sed to replace the existing value&#10;    sed -i &apos;&apos; &quot;s/^$KEY_TO_UPDATE = .*/$KEY_TO_UPDATE = $NEW_VALUE/&quot; &quot;$CONFIG_FILE_DEBUG&quot;&#10;else&#10;    echo &quot;$CONFIG_FILE not found!&quot;&#10;    exit 1&#10;fi&#10;if [ -f &quot;$CONFIG_FILE_RELEASE&quot; ]; then&#10;    # Use sed to replace the existing value&#10;    sed -i &apos;&apos; &quot;s/^$KEY_TO_UPDATE = .*/$KEY_TO_UPDATE = $NEW_VALUE/&quot; &quot;$CONFIG_FILE_RELEASE&quot;&#10;else&#10;    echo &quot;$CONFIG_FILE not found!&quot;&#10;    exit 1&#10;fi&#10;&#10;KEY_TO_UPDATE=&quot;BUILD_NUMBER&quot;&#10;BUILD=$(date +%s)&#10;NEW_VALUE=&quot;build:${BUILD}&quot;&#10;&#10;# Check if the config file exists&#10;if [ -f &quot;$CONFIG_FILE_DEBUG&quot; ]; then&#10;    # Use sed to replace the existing value&#10;    sed -i &apos;&apos; &quot;s/^$KEY_TO_UPDATE = .*/$KEY_TO_UPDATE = $NEW_VALUE/&quot; &quot;$CONFIG_FILE_DEBUG&quot;&#10;else&#10;    echo &quot;$CONFIG_FILE not found!&quot;&#10;    exit 1&#10;fi&#10;if [ -f &quot;$CONFIG_FILE_RELEASE&quot; ]; then&#10;    # Use sed to replace the existing value&#10;    sed -i &apos;&apos; &quot;s/^$KEY_TO_UPDATE = .*/$KEY_TO_UPDATE = $NEW_VALUE/&quot; &quot;$CONFIG_FILE_RELEASE&quot;&#10;else&#10;    echo &quot;$CONFIG_FILE not found!&quot;&#10;    exit 1&#10;fi&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "434F84D82ACFE50A005077F5"
