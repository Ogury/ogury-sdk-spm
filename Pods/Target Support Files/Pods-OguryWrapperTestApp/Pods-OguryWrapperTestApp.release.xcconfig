CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/OguryAds-Prod" "${PODS_ROOT}/OguryChoiceManager-Prod" "${PODS_ROOT}/OguryCore-Prod" "${PODS_XCFRAMEWORKS_BUILD_DIR}/OguryAds-Prod" "${PODS_XCFRAMEWORKS_BUILD_DIR}/OguryAds-Prod/OMID" "${PODS_XCFRAMEWORKS_BUILD_DIR}/OguryChoiceManager-Prod" "${PODS_XCFRAMEWORKS_BUILD_DIR}/OguryCore-Prod"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
OTHER_LDFLAGS = $(inherited) -ObjC -l"z" -framework "AdSupport" -framework "Foundation" -framework "OMSDK_Ogury" -framework "OguryAds" -framework "OguryChoiceManager" -framework "OguryCore" -framework "SystemConfiguration" -framework "UIKit" -weak_framework "CoreTelephony"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/../..
PODS_ROOT = ${SRCROOT}/../../Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
